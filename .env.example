# =============================================================================
# TSE Stock Screener — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# Telegram Bot (for signal alerts)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Chat ID for sending messages
# Use @userinfobot or @getmyid_bot to find your chat ID
TELEGRAM_CHAT_ID=

# Optional: J-Quants API (future use)
# JQUANTS_EMAIL=
# JQUANTS_PASSWORD=

# Optional: Rakuten Securities API (future use)
# RAKUTEN_APP_KEY=
# RAKUTEN_SECRET_KEY=
