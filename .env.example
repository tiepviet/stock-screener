# =============================================================================
# TSE Stock Screener — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# === Bootstrap admin (auto-created on first startup) ===
# On first launch, if the users table is empty AND both vars are set,
# the admin account is created automatically. The SQLite DB itself is
# created on first launch (gitignored under data/). After that, the
# login form on the dashboard accepts this username/password.
#
# Password must be at least 8 characters.
TSE_ADMIN_USER=admin
TSE_ADMIN_PASSWORD=change-me-now-please

# === Telegram (for signal alerts) ===
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Use @userinfobot or @getmyid_bot to find your chat ID
TELEGRAM_CHAT_ID=

# === Slack (for signal alerts) ===
# Create an Incoming Webhook in Slack API > Apps > Incoming Webhooks
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# === Optional: Broker APIs (future use) ===
# JQUANTS_EMAIL=
# JQUANTS_PASSWORD=
# RAKUTEN_APP_KEY=
# RAKUTEN_SECRET_KEY=
